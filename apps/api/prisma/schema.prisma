// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  STAFF
  MANAGER
}

enum WorkflowStatus {
  CREATED
  ASSIGNED
  IN_PROGRESS
  DONE
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

model Department {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())
  users     User[]
  documents Document[]
}

model User {
  id          Int        @id @default(autoincrement())
  name        String
  email       String     @unique
  password    String
  role        Role       @default(STAFF)
  departmentId Int?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  department  Department? @relation(fields: [departmentId], references: [id])
  documents   Document[]
  logs        Log[]
  notifications Notification[]
  sentShares  DocumentShare[] @relation("DocumentSharedBy")
  receivedShares DocumentShare[] @relation("DocumentSharedTo")
  versionUploads DocumentVersion[]

  assignedDocuments Document[] @relation("DocumentAssignedTo")
  comments DocumentComment[]
}

model Category {
  id        Int        @id @default(autoincrement())
  name      String     @unique
  createdAt DateTime   @default(now())
  documents Document[]
}

model Document {
  id           Int           @id @default(autoincrement())
  title        String
  originalName String
  filePath     String
  mimeType     String
  fileSize     Int
  currentVersion Int         @default(1)
  uploadedById Int
  categoryId   Int
  departmentId Int?
  assignedToId Int?
  workflowStatus WorkflowStatus @default(CREATED)
  approvalStatus ApprovalStatus @default(PENDING)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  uploadedBy   User          @relation(fields: [uploadedById], references: [id])
  category     Category      @relation(fields: [categoryId], references: [id])
  department   Department?   @relation(fields: [departmentId], references: [id])
  assignedTo   User?         @relation("DocumentAssignedTo", fields: [assignedToId], references: [id])
  tags         DocumentTag[]
  logs         Log[]
  versions     DocumentVersion[]
  shares       DocumentShare[]
  notifications Notification[]
  comments     DocumentComment[]
}

model DocumentComment {
  id         Int      @id @default(autoincrement())
  documentId Int
  authorId   Int
  message    String
  createdAt  DateTime @default(now())

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  author   User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([documentId, createdAt])
}

model DocumentVersion {
  id           Int      @id @default(autoincrement())
  documentId   Int
  versionNumber Int
  originalName  String
  filePath     String
  mimeType     String
  fileSize     Int
  uploadedById Int
  createdAt    DateTime @default(now())
  document     Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  uploadedBy   User     @relation(fields: [uploadedById], references: [id])

  @@unique([documentId, versionNumber])
  @@index([documentId])
}

model DocumentShare {
  id          Int      @id @default(autoincrement())
  documentId  Int
  sharedById  Int
  sharedToId  Int
  message     String?
  createdAt   DateTime @default(now())
  readAt      DateTime?
  document    Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  sharedBy    User     @relation("DocumentSharedBy", fields: [sharedById], references: [id])
  sharedTo    User     @relation("DocumentSharedTo", fields: [sharedToId], references: [id])
}

model DocumentTag {
  id         Int      @id @default(autoincrement())
  name       String
  documentId Int
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([name])
}

model Log {
  id         Int       @id @default(autoincrement())
  userId     Int
  documentId Int?
  action     String
  detail     String?
  timestamp  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id])
  document   Document? @relation(fields: [documentId], references: [id])

  @@index([timestamp])
}

model Notification {
  id         Int       @id @default(autoincrement())
  userId     Int
  documentId Int?
  action     String
  title      String
  detail     String?
  isRead     Boolean   @default(false)
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  document   Document? @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
}
