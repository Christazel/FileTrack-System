{
  "name": "filetrack-system",
  "version": "1.0.0",
  "description": "FileTrack System monorepo",
  "main": "index.js",
  "scripts": {
    "dev": "concurrently \"npm --prefix apps/api run dev\" \"npm --prefix apps/web run dev\"",
    "dev:api": "npm --prefix apps/api run dev",
    "dev:web": "npm --prefix apps/web run dev",
    "build:web": "npm --prefix apps/web run build",
    "lint:web": "npm --prefix apps/web run lint",
    "smoke:api": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/smoke-api.ps1",
    "start:api": "npm --prefix apps/api run start",
    "seed": "npm --prefix apps/api run prisma:seed",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:logs": "docker logs -f filetrack-mysql",
    "prisma:generate": "npm --prefix apps/api run prisma:generate",
    "prisma:migrate": "npm --prefix apps/api run prisma:migrate",
    "prisma:studio": "cd apps/api && npx prisma studio"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
